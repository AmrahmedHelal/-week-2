void Aggregation()
{
    var heaterId = Repository.Heaters.First().HeaterId;

    var totalHours = Repository.DailyUsages
        .Where(u => u.HeaterId == heaterId)
        .Sum(u => u.HoursWorked);

    Console.WriteLine($"Total Heater Hours : {totalHours}");

    var minPower = Repository.Heaters.Min(h => h.PowerValue);
    var maxPower = Repository.Heaters.Max(h => h.PowerValue);
    var avgPower = Repository.Heaters.Average(h => h.PowerValue);

    Console.WriteLine($"Min Power: {minPower}");
    Console.WriteLine($"Max Power: {maxPower}");
    Console.WriteLine($"Avg Power: {avgPower}");

    var topHouses = Repository.DailyUsages
    .GroupBy(u => u.HouseId)
    .Select(g => new
    {
        HouseId = g.Key,
        TotalHours = g.Sum(x => x.HoursWorked)
    })
    .OrderByDescending(x => x.TotalHours)
    .Take(5)
    .ToList();

    var csv = topHouses.Aggregate("",
    (R, h) => R + $"{h.HouseId}:{h.TotalHours},",
    result => result.TrimEnd(','));

    Console.WriteLine("\nTop 5 Houses CSV:");
    Console.WriteLine(csv);
}
void SetOperations()
{
    //Use Distinct on a projection (e.g., CityZone list)
    var zones = houses
    .Select(h => h.CityZone)
    .Distinct();

    Console.WriteLine("Distinct CityZones:");
    Console.WriteLine(string.Join(", ", zones));
    //Union heaters from two owners

    var owner01 =owners[0];
    var owner02 = owners[1];

    var heaters01 = houses
        .Where(h => h.OwnerId == owner01.OwnerId)
        .SelectMany(h => h.Heaters)
        .Select(h => h.HeaterId);

    var heaters02 = houses
        .Where(h => h.OwnerId == owner02.OwnerId)
        .SelectMany(h => h.Heaters)
        .Select(h => h.HeaterId);

    var union = heaters02.Union(heaters02);

    Console.WriteLine("\nUnion Heaters:");
    Console.WriteLine(string.Join("\n", union));
    Console.WriteLine("Count: " + union.Count());
    //InterSect
    var zone1 = houses[0].CityZone;
    var zone2 = houses[1].CityZone;

    var heatersZone1 = houses
        .Where(h => h.CityZone == zone1)
        .SelectMany(h => h.Heaters);


    var heatersZone2 = houses
        .Where(h => h.CityZone == zone2)
        .SelectMany(h => h.Heaters);
      

    var common = heatersZone1.Intersect(heatersZone2);

    Console.WriteLine("\nIntersect Heaters:");
    Console.WriteLine(string.Join("\n", common));//zero 
    Console.WriteLine("Count: " + common.Count());

    //Except

    var onlyIn01 =heaters01.Except(heaters02);
    Console.WriteLine("\nHeaters in Zone1 not in Zone2:");
    Console.WriteLine(string.Join("\n", onlyIn01));
    Console.WriteLine("Count: " + onlyIn01.Count());

    //Distinct

    var distinctHeaters = heaters.DistinctBy(h => h.PowerValue);
    Console.WriteLine("\nDistinctBy PowerValue:");
    Console.WriteLine(string.Join("\n", distinctHeaters.Select(h => h.HeaterId)));

}

static void DisplayHeater(IEnumerable<Heater> heaters)
{
