    {
        Console.WriteLine($"houseid : {h.HouseId} heaterId: {h.HeaterId}  PowerValue : {h.PowerValue} heaterType: {h.HeaterType} ");
    }
    Console.WriteLine($"Length {heaters.Count()}");
    Console.WriteLine("===============================================");
}
